# contextbudget-cloud — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Full asyncpg-compatible connection string
DATABASE_URL=postgresql://contextbudget:CHANGE_ME@localhost:5432/contextbudget

# Optional: read replica URL for analytics queries (multi-region setup).
# When set, /analytics/* and /dashboard/* endpoints query the replica instead
# of the primary, keeping read load off the write path.
# READ_DATABASE_URL=postgresql://contextbudget:CHANGE_ME@replica-host:5432/contextbudget

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Bind host for uvicorn
HOST=0.0.0.0

# Bind port
PORT=8080

# ---------------------------------------------------------------------------
# Security — REQUIRED in production
# ---------------------------------------------------------------------------

# Admin bootstrap token — required for POST /orgs.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
CB_CLOUD_ADMIN_TOKEN=CHANGE_ME_generate_with_secrets_token_hex_32

# PostgreSQL password (used in docker-compose.prod.yml)
POSTGRES_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------

# Max events per API key per window (default: 500 per 60 seconds)
CB_CLOUD_EVENTS_RATE_LIMIT=500
CB_CLOUD_EVENTS_RATE_WINDOW=60

# ---------------------------------------------------------------------------
# OIDC / SSO (optional — leave empty to use API-key auth only)
# ---------------------------------------------------------------------------

CB_CLOUD_OIDC_ENABLED=false
# CB_CLOUD_OIDC_ISSUER=https://accounts.google.com
# CB_CLOUD_OIDC_AUDIENCE=your-client-id
# CB_CLOUD_OIDC_JWKS_URI=   # optional override; defaults to {issuer}/.well-known/jwks.json

# ---------------------------------------------------------------------------
# Platform webhook adapters (optional)
# ---------------------------------------------------------------------------

# Slack Incoming Webhook URL for policy alerts
CB_CLOUD_SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 routing key
CB_CLOUD_PAGERDUTY_ROUTING_KEY=

# ---------------------------------------------------------------------------
# Stripe billing (optional)
# ---------------------------------------------------------------------------

CB_CLOUD_BILLING_ENABLED=false
# CB_CLOUD_STRIPE_SECRET_KEY=sk_live_...
# CB_CLOUD_STRIPE_METER_ID=mtr_...   # create with: stripe meters create --event-name cb_tokens_used

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
