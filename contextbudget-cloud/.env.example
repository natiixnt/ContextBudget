# contextbudget-cloud — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Full asyncpg-compatible connection string
DATABASE_URL=postgresql://contextbudget:CHANGE_ME@localhost:5432/contextbudget

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Bind host for uvicorn
CB_CLOUD_HOST=0.0.0.0

# Bind port
CB_CLOUD_PORT=8080

# Number of uvicorn worker processes (set to 1 for single-machine deployments)
CB_CLOUD_WORKERS=2

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Secret salt for API key hashing — CHANGE THIS in production
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# (The current implementation uses SHA-256 without a salt; this env var is
#  reserved for a future HMAC-based upgrade.)
CB_CLOUD_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
