# ContextBudget CLI / Gateway — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Gateway settings (contextbudget gateway)
# ---------------------------------------------------------------------------

# Bind address and port for the runtime gateway
RC_GATEWAY_HOST=127.0.0.1
RC_GATEWAY_PORT=8787

# Default token budget (tokens) applied when a request omits max_tokens
RC_GATEWAY_MAX_TOKENS=128000

# Default max files per context pack
RC_GATEWAY_MAX_FILES=100

# Bearer token required for all gateway requests (leave empty to disable auth)
RC_GATEWAY_API_KEY=

# Per-request processing timeout in seconds
RC_GATEWAY_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Cloud control plane integration (optional)
# ---------------------------------------------------------------------------

# URL of your contextbudget-cloud deployment (e.g. https://cloud.example.com)
RC_GATEWAY_CLOUD_POLICY_URL=

# API key issued by contextbudget-cloud (cbk_...)
RC_GATEWAY_CLOUD_API_KEY=

# Organization ID in contextbudget-cloud (integer)
RC_GATEWAY_CLOUD_ORG_ID=

# ---------------------------------------------------------------------------
# Webhook push notifications (optional)
# ---------------------------------------------------------------------------

# Endpoint to receive policy violation and budget overrun events
RC_GATEWAY_WEBHOOK_URL=

# HMAC-SHA256 signing secret; sent as X-CB-Signature-256 header
RC_GATEWAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Redis session store (optional — enables horizontal gateway scaling)
# ---------------------------------------------------------------------------

# Redis URL for distributed session storage.
# When set, /run-agent-step sessions are stored in Redis so any replica can
# continue a session started on another node.
# Format: redis://[:password@]host[:port][/db]
RC_GATEWAY_REDIS_URL=

# Session TTL in seconds (default: 86400 = 24 h)
RC_GATEWAY_SESSION_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Telemetry (optional)
# ---------------------------------------------------------------------------

# Enable gateway telemetry event emission
RC_GATEWAY_TELEMETRY=false
